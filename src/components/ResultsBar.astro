---
import type { Result } from '../lib/api.model'

interface Props {
  results: Result[]
}

const { results } = Astro.props
---

<!-- gap-px + bg creates the 1px border lines between cells -->
<div class="grid gap-px rounded-xl overflow-hidden bg-fg/8" style={`grid-template-columns: repeat(${results.length}, 1fr)`}>
  {results.map(result => (
    <div class="bg-card flex flex-col items-center text-center gap-3 px-8 py-10 transition-colors duration-200 hover:bg-accent-light">
      <span class="font-serif text-[44px] font-light text-accent leading-none">{result.value}</span>
      <span class="font-sans text-[12px] text-muted leading-snug max-w-35">{result.label}</span>
    </div>
  ))}
</div>

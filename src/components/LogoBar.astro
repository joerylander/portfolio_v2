---
interface Props {
  clients: string[]
}

const { clients } = Astro.props
---

<div class="px-[52px] pb-16 max-md:px-6">
  <div class="flex items-center gap-10 flex-wrap border-b border-fg/8 pb-8">
    <span class="font-mono text-[11px] text-faint uppercase tracking-[0.1em] shrink-0">
      Worked with
    </span>
    {clients.map(name => (
      <span class="font-sans text-[13px] font-medium text-faint">{name}</span>
    ))}
  </div>
</div>

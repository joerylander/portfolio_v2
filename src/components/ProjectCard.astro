---
import type { Project } from '../lib/api'

interface Props {
  project: Project
  featured?: boolean
}

const { project, featured = false } = Astro.props
const topResult = project.results[0]
---

{featured ? (
  <!-- Featured two-column layout -->
  <a
    href={`/work/${project.slug}`}
    class=" no-underline bg-card border border-fg/8 rounded-xl overflow-hidden
           transition-[border-color,transform] duration-200 hover:-translate-y-0.75 hover:border-fg/20
           grid grid-cols-[1fr_1fr] items-stretch"
  >
    <!-- Image -->
    <div class="overflow-hidden">
      {project.thumbnail_url ? (
        <img src={project.thumbnail_url} alt={project.title} class="w-full h-full object-cover" />
      ) : (
        <div class="w-full h-full bg-accent-light min-h-60"></div>
      )}
    </div>

    <!-- Body -->
    <div class="p-8 flex flex-col justify-center">
      <div class="flex flex-wrap gap-1.5 mb-4">
        {project.tags.map((tag: string) => (
          <span class="font-mono text-[11px] text-muted bg-bg border border-fg/8 px-2 py-0.75 rounded-md">{tag}</span>
        ))}
      </div>
      <h3 class="font-serif text-[26px] font-light text-fg leading-snug mb-3">{project.title}</h3>
      <p class="font-sans text-[13px] text-muted leading-relaxed mb-6">{project.summary}</p>
      <div class="flex items-center justify-between">
        <span class="font-mono text-[11px] text-faint">{project.client} · {project.year}</span>
        {topResult && (
          <span class="font-mono text-[11px] text-available">↑ {topResult.label}</span>
        )}
      </div>
      <span class="font-sans text-[13px] text-muted mt-5 hover:text-fg transition-colors group-hover:text-fg">
        View case study →
      </span>
    </div>
  </a>
) : (
  <!-- Standard card -->
  <a
    href={`/work/${project.slug}`}
    class="block no-underline bg-card border border-fg/8 rounded-xl overflow-hidden
           transition-[border-color,transform] duration-200 hover:-translate-y-0.75 hover:border-fg/20"
  >
    <!-- Image -->
    <div class="border-b border-fg/8 aspect-video">
      {project.thumbnail_url ? (
        <img src={project.thumbnail_url} alt={project.title} class="w-full h-full object-cover" />
      ) : (
        <div class="w-full h-full bg-bg"></div>
      )}
    </div>

    <!-- Body -->
    <div class="p-6">
      <div class="flex flex-wrap gap-1.5 mb-3">
        {project.tags.map((tag: string) => (
          <span class="font-mono text-[11px] text-muted bg-bg border border-fg/8 px-2 py-0.75 rounded-md">{tag}</span>
        ))}
      </div>
      <h3 class="font-sans text-[16px] font-medium text-fg mb-2 leading-snug">{project.title}</h3>
      <p class="font-sans text-[13px] text-muted leading-relaxed mb-5">{project.summary}</p>
      <div class="flex items-center justify-between">
        <span class="font-mono text-[11px] text-faint">{project.client} · {project.year}</span>
        {topResult && (
          <span class="font-mono text-[11px] text-available">↑ {topResult.label}</span>
        )}
      </div>
    </div>
  </a>
)}

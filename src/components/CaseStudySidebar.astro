---
import type { Testimonial } from '@/models/testimonial'
import type { TimelineItem } from '@/models/project'

interface Props {
  testimonial?: Testimonial
  timeline?: TimelineItem[]
  deliverables?: string[]
}

const { testimonial, timeline = [], deliverables = [] } = Astro.props
const initials = testimonial
  ? testimonial.author.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase()
  : ''
---

<aside class="flex flex-col gap-4">

  <!-- Card 1: Testimonial -->
  {testimonial && (
    <div class="bg-fg rounded-xl p-6">
      <span class="font-mono text-3xl text-accent leading-none block mb-3">"</span>
      <blockquote class="m-0 mb-5">
        <p class="font-serif text-base font-light italic text-card leading-relaxed">
          {testimonial.quote}
        </p>
      </blockquote>
      <div class="flex items-center gap-3">
        {testimonial.avatarUrl ? (
          <img
            src={testimonial.avatarUrl}
            alt={testimonial.author}
            class="w-8 h-8 rounded-full object-cover shrink-0"
          />
        ) : (
          <div class="w-8 h-8 rounded-full bg-card/10 border border-card/20 flex items-center justify-center shrink-0">
            <span class="font-mono text-xs text-card">{initials}</span>
          </div>
        )}
        <div>
          <p class="font-sans text-sm font-medium text-card leading-none mb-0.5">{testimonial.author}</p>
          <p class="font-mono text-xs text-card/40">
            {testimonial.role}{testimonial.company ? `, ${testimonial.company}` : ''}
          </p>
        </div>
      </div>
    </div>
  )}

  <!-- Card 2: Timeline -->
  {timeline.length > 0 && (
    <div class="bg-card border border-fg/8 rounded-xl overflow-hidden">
      <div class="px-5 py-4 border-b border-fg/8">
        <span class="font-sans text-sm font-medium text-fg">Timeline</span>
      </div>
      <div>
        {timeline.map((item, i) => (
          <div class:list={[
            'flex items-center justify-between px-5 py-3',
            i < timeline.length - 1 ? 'border-b border-fg/8' : '',
          ]}>
            <span class="font-sans text-sm text-fg">{item.phase}</span>
            <span class="font-mono text-xs text-muted">{item.duration}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Card 3: Deliverables -->
  {deliverables.length > 0 && (
    <div class="bg-card border border-fg/8 rounded-xl overflow-hidden">
      <div class="px-5 py-4 border-b border-fg/8">
        <span class="font-sans text-sm font-medium text-fg">Deliverables</span>
      </div>
      <ul class="list-none m-0 p-0 px-5 py-3 flex flex-col gap-3">
        {deliverables.map(item => (
          <li class="flex items-start gap-3">
            <!-- Check circle -->
            <span class="shrink-0 mt-0.5 w-4 h-4 rounded-full bg-accent-light border border-accent/30 flex items-center justify-center">
              <span class="block w-1.5 h-1.5 rounded-full bg-accent"></span>
            </span>
            <span class="font-sans text-sm text-fg leading-snug">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  )}

</aside>

---
import type { Project } from '../lib/api'
import FeaturedProject from './FeaturedProject.astro'

interface Props {
  featuredProject: Project | null
}

const { featuredProject } = Astro.props
---

<section class="grid grid-cols-[1fr_380px] gap-12 items-start px-13 py-20 max-md:grid-cols-1 max-md:px-6 max-md:py-12">

  <!-- Left: copy -->
  <div>
    <!-- Eyebrow -->
    <div class="flex items-center gap-3 mb-8">
      <div class="w-7 h-px bg-accent shrink-0"></div>
      <span class="font-mono text-[11px] text-accent uppercase tracking-widest">Freelance web developer</span>
    </div>

    <!-- Headline -->
    <h1 class="font-serif text-[64px] leading-[1.05] font-light text-fg mb-6 max-md:text-[44px]">
      Websites that work<br />
      <em class="text-accent not-italic">as hard as you do.</em>
    </h1>

    <!-- Subheading -->
    <p class="font-sans text-[16px] text-muted leading-relaxed mb-10 max-w-md">
      I help startups, agencies, and small businesses ship fast, polished web experiences — from first sketch to production deployment.
    </p>

    <!-- CTAs -->
    <div class="flex items-center gap-5 flex-wrap">
      <a
        href="/work"
        class="font-sans text-[13px] font-medium text-card bg-fg no-underline px-7 py-3 rounded-md hover:opacity-85 transition-opacity"
      >
        View my work
      </a>
      <a
        href="/process"
        class="font-sans text-[13px] text-muted no-underline hover:text-fg transition-colors group"
      >
        How I work <span class="inline-block transition-transform duration-150 group-hover:translate-x-0.75">→</span>
      </a>
    </div>
  </div>

  <!-- Right: featured project card -->
  {featuredProject && <FeaturedProject project={featuredProject} />}
</section>

---
interface Service {
  number: string
  title: string
  description: string
}

interface Props {
  services: Service[]
}

const { services } = Astro.props
---

<section class="px-13 py-16 max-md:px-6">
  <!-- Eyebrow -->
  <div class="flex items-center gap-3 mb-10">
    <div class="w-7 h-px bg-accent shrink-0"></div>
    <span class="font-mono text-[11px] text-accent uppercase tracking-widest">What I do</span>
  </div>

  <div class="grid grid-cols-3 gap-4 max-md:grid-cols-1">
    {services.map(service => (
      <div class="bg-card border border-fg/8 rounded-xl p-8 transition-[border-color] duration-200 hover:border-accent">
        <span class="font-mono text-[11px] text-accent block mb-4">{service.number}</span>
        <h3 class="font-sans text-[15px] font-medium text-fg mb-3">{service.title}</h3>
        <p class="font-sans text-[13px] text-muted leading-relaxed">{service.description}</p>
      </div>
    ))}
  </div>
</section>

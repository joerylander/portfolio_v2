---
import Base from '../layouts/Base.astro'
import ContactForm from '../components/ContactForm.jsx'
---

<Base
  title="Contact — Joe Rylander"
  description="Get in touch about your project. I typically respond within 12 hours."
>
  <div class="px-13 pt-16 pb-20 max-md:px-6">
    <div class="grid grid-cols-[1fr_480px] gap-20 items-start max-lg:grid-cols-1 max-lg:gap-12">

      <!-- Left: context -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <div class="w-7 h-px bg-accent shrink-0"></div>
          <span class="font-mono text-xs text-accent uppercase tracking-widest">Get in touch</span>
        </div>

        <h1 class="font-serif text-5xl font-light text-fg leading-[1.05] mb-6 max-md:text-4xl">
          Let's talk about<br /><em class="text-accent not-italic">your project.</em>
        </h1>

        <p class="font-sans text-sm text-muted leading-relaxed mb-10 max-w-sm">
          Tell me what you're building and what you need. I respond within 12 hours and will let you know if I'm a good fit.
        </p>

        <!-- Availability -->
        <div class="flex items-center gap-2 font-mono text-xs text-muted mb-10">
          <span class="block w-1.5 h-1.5 rounded-full bg-available shrink-0"></span>
          Currently taking on new projects
        </div>

        <!-- Direct email -->
        <div class="border-t border-fg/8 pt-8">
          <p class="font-sans text-sm text-muted mb-2">Prefer email?</p>
          <a
            href="mailto:hello@joerylander.com"
            class="font-sans text-sm text-fg no-underline hover:text-accent transition-colors"
          >
            hello@joerylander.com
          </a>
        </div>
      </div>

      <!-- Right: form -->
      <div class="bg-card border border-fg/8 rounded-xl p-8 max-md:p-6">
        <ContactForm client:load />
      </div>

    </div>
  </div>
</Base>
